# Database
DATABASE_URL=postgresql://goodnews:goodnews@localhost:5432/goodnews

# Redis
REDIS_URL=redis://localhost:6379

# AI
ANTHROPIC_API_KEY=sk-ant-your-key-here

# News Sources
NEWS_API_KEY=your-newsapi-org-key-here

# Comma-separated list of good-news RSS feed URLs
# Leave empty to use defaults (positive.news, goodnewsnetwork.org, etc.)
RSS_FEEDS=https://www.positive.news/feed/,https://www.goodnewsnetwork.org/feed/

# Twitter / X API
TWITTER_BEARER_TOKEN=your-twitter-bearer-token-here

# Server
PORT=3001
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# Frontend (Vite)
VITE_API_URL=/api
