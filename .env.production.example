# ── Database (provided automatically by Railway/Supabase) ─────────────────────
DATABASE_URL=postgresql://user:password@host:5432/goodnews

# ── Redis (provided automatically by Railway/Upstash) ─────────────────────────
REDIS_URL=redis://default:password@host:6379

# ── AI (free at console.groq.com) ─────────────────────────────────────────────
GROQ_API_KEY=gsk_...

# ── Optional: NewsAPI.org (free tier, 100 req/day) ────────────────────────────
NEWS_API_KEY=

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── CORS: your Vercel frontend URL ────────────────────────────────────────────
FRONTEND_URL=https://your-app.vercel.app

# ── Frontend (set this in Vercel dashboard as env var) ─────────────────────────
# VITE_API_URL=https://your-api.railway.app/api

# ── VPS only: postgres password for docker-compose.prod.yml ───────────────────
POSTGRES_PASSWORD=change_me_strong_password
