FROM node:20-alpine AS base
WORKDIR /app

RUN apk add --no-cache python3 make g++

COPY package.json ./
COPY shared/package.json ./shared/
COPY agents/fetcher/package.json ./agents/fetcher/
COPY agents/deduper/package.json ./agents/deduper/
COPY agents/classifier/package.json ./agents/classifier/
COPY agents/summarizer/package.json ./agents/summarizer/
COPY agents/reshare/package.json ./agents/reshare/
COPY agents/analytics/package.json ./agents/analytics/
COPY api/package.json ./api/
COPY frontend/package.json ./frontend/

RUN npm install --workspace=shared \
    --workspace=agents/fetcher \
    --workspace=agents/deduper \
    --workspace=agents/classifier \
    --workspace=agents/summarizer \
    --workspace=agents/reshare \
    --workspace=agents/analytics \
    --ignore-scripts

COPY shared/ ./shared/
COPY agents/ ./agents/

ARG AGENT
ENV AGENT=${AGENT}

CMD ["sh", "-c", "node --require ts-node/register agents/${AGENT}/src/index.ts"]
